# <!-- Audit: B.4 (b4-mobile-only, FR-MO-032) -->
# Copy this file to .envrc (gitignored), fill in your secrets, then `direnv allow`.
# These environment variables are referenced by Fastlane and CI workflows.
#
# NEVER commit .envrc — it is in .gitignore. NEVER hard-code these values
# into Fastfile / Appfile / Matchfile templates.

# ── iOS ─────────────────────────────────────────────────────────────
# App Store Connect API key (.p8 file). Path relative to repo root.
export APP_STORE_CONNECT_API_KEY_PATH="./secrets/AuthKey_XXXXXXXXXX.p8"

# Apple ID (developer account email).
export APPLE_ID="developer@example.com"

# Fastlane team IDs (Apple Developer Account → Membership).
export FASTLANE_TEAM_ID="XXXXXXXXXX"
export FASTLANE_ITC_TEAM_ID="XXXXXXXX"

# `match` configuration (private repo holding code-signing certs).
export MATCH_GIT_URL="git@github.com:your-org/match-certs.git"
export MATCH_PASSWORD="REPLACE_ME"
export MATCH_KEYCHAIN_PASSWORD="REPLACE_ME"
export MATCH_GIT_BASIC_AUTHORIZATION=""  # base64(user:token), only on CI

# ── Android ─────────────────────────────────────────────────────────
# Play Console service account JSON key.
export PLAY_STORE_JSON_KEY="./secrets/play-store-key.json"

# Upload keystore for signing release AAB.
export KEYSTORE_PATH="./secrets/upload-keystore.jks"
export KEYSTORE_PASSWORD="REPLACE_ME"
export KEY_ALIAS="upload"
export KEY_PASSWORD="REPLACE_ME"
