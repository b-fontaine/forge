# <project-name> — local dev environment. Copy to .env and fill in.
# .env is gitignored and MUST NEVER be committed.

# ── Postgres event store ──
POSTGRES_DB=<project-name>_dev
POSTGRES_USER=<project-name>_user
POSTGRES_PASSWORD=change-me-locally
DATABASE_URL=postgres://<project-name>_user:change-me-locally@localhost:5432/<project-name>_dev
ARG_DB_PORT=5432

# ── NATS JetStream ──
NATS_URL=nats://localhost:4222
ARG_NATS_PORT=4222

# ── Temporal (optional local-dev overlay; see infra/temporal/) ──
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=<project-name>-sagas

# ── Backend ──
ARG_BACKEND_PORT=8080
LOG_LEVEL=info
