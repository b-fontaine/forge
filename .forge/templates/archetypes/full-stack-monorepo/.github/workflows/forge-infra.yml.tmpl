# <!-- Audit: B.1.9 (b1-delivery, FR-IN-004) -->
# Reference per-layer infra CI workflow. Standard:
# .forge/standards/infra/ci-workflows.md
#
# Triggers on `pull_request` and `push`. Uses dorny/paths-filter@v3
# scoped to infra/**. Steps in order: kustomize build for each of
# the three overlays (dev, staging, prod) → kubeconform --strict
# against each rendered overlay → verify.sh → constitution-linter.sh.
# Kustomize and kubeconform versions pinned in setup steps (ADR-008).

name: forge-infra

on:
  pull_request:
    branches: [main]
  push:
    branches: [main]

concurrency:
  group: forge-infra-<project-name>-${{ github.ref }}
  cancel-in-progress: true

permissions:
  contents: read

jobs:
  filter:
    name: Detect infra changes
    runs-on: ubuntu-latest
    outputs:
      infra: ${{ steps.changes.outputs.infra }}
    steps:
      - uses: actions/checkout@v4
      - uses: dorny/paths-filter@v3
        id: changes
        with:
          filters: |
            infra:
              - 'infra/**'

  validate:
    name: Render + validate overlays
    needs: filter
    if: needs.filter.outputs.infra == 'true'
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Install kustomize (pinned)
        uses: imranismail/setup-kustomize@v2
        with:
          kustomize-version: "5.4.2"

      - name: Install kubeconform (pinned)
        run: |
          set -euo pipefail
          KUBECONFORM_VERSION="0.6.7"
          curl -sSLO "https://github.com/yannh/kubeconform/releases/download/v${KUBECONFORM_VERSION}/kubeconform-linux-amd64.tar.gz"
          tar -xzf kubeconform-linux-amd64.tar.gz kubeconform
          sudo install -m 0755 kubeconform /usr/local/bin/kubeconform
          kubeconform -v

      - name: kustomize build infra/k8s/overlays/dev
        run: kustomize build infra/k8s/overlays/dev > /tmp/dev.yaml

      - name: kustomize build infra/k8s/overlays/staging
        run: kustomize build infra/k8s/overlays/staging > /tmp/staging.yaml

      - name: kustomize build infra/k8s/overlays/prod
        run: kustomize build infra/k8s/overlays/prod > /tmp/prod.yaml

      - name: kubeconform --strict (dev)
        run: kubeconform --summary --strict /tmp/dev.yaml

      - name: kubeconform --strict (staging)
        run: kubeconform --summary --strict /tmp/staging.yaml

      - name: kubeconform --strict (prod)
        run: kubeconform --summary --strict /tmp/prod.yaml

      - name: verify.sh
        run: bash .forge/scripts/verify.sh

      - name: constitution-linter.sh
        run: bash .forge/scripts/constitution-linter.sh
