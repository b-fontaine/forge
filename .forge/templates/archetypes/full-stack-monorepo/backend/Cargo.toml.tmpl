# <!-- Audit: B.1.2 (part of b1-scaffolder, backend workspace manifest) -->
# <!-- Overlay: workspace manifest, not generated by cargo new. See design ADR-002. -->
#
# This file is rendered BEFORE the cargo new invocations so that each
# `cargo new --lib crates/<name> --vcs none` detects the parent workspace
# and writes a workspace-aware Cargo.toml inside the crate directory.

[workspace]
resolver = "2"
members = [
  "crates/domain",
  "crates/application",
  "crates/grpc-api",
  "crates/infrastructure",
  "bin-server",
]

# Shared workspace dependencies — pin canonical versions so every crate
# inherits them with `dep.workspace = true` instead of re-declaring.
[workspace.dependencies]
# ── Async / runtime ──
tokio = { version = "1", features = ["full"] }
futures = "0.3"
async-trait = "0.1"

# ── Error handling (rust/error-handling standard) ──
thiserror = "1"
anyhow = "1"

# ── Observability (b1-delivery will wire this) ──
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter"] }

# ── gRPC (rust/grpc standard) ──
tonic = "0.12"
prost = "0.13"
tonic-build = "0.12"

# ── HTTP / transport (T5.1.E follow-on, t5-bin-server-deps) ──
# axum 0.8 is required by connectrpc 0.3.3 (declares `axum = "^0.8"`).
axum = "0.8"
tower-http = { version = "0.6", features = ["trace"] }
http = "1"

# ── Database (infrastructure layer) ──
sqlx = { version = "0.8", features = ["runtime-tokio-rustls", "postgres", "macros"] }

# ── Testing ──
proptest = "1"
mockall = "0.13"
tokio-test = "0.4"

# ── Serialization ──
serde = { version = "1", features = ["derive"] }
serde_json = "1"

# Profiles : let each crate pick its own ; workspace-level overrides are
# discouraged (they leak across layers).
