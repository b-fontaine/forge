# <!-- Audit: B.1.2 (part of b1-scaffolder, docker-compose.dev template) -->

# =============================================================================
# docker-compose.dev.yml — full-stack-monorepo archetype (LOCAL DEV ONLY)
#
# Archetype : full-stack-monorepo
# Standard  : .forge/standards/infra/docker-compose.md
#
# Services declared in this stack:
#   fsm-db       — PostgreSQL 16 relational datastore (primary persistence layer)
#   fsm-backend  — Application backend (Rust gRPC service or equivalent)
#   fsm-kong     — API gateway (Kong 3), handling REST↔gRPC transcoding
#
# IMPORTANT — before running `task dev:up`:
#   1. Copy .env.example to .env   →   cp .env.example .env
#   2. Fill in all required values in .env (DB password, ports, etc.)
#   .env MUST exist locally — the stack will refuse to start without it.
#   .env is gitignored and MUST NEVER be committed.
#
# WARNING: this is the DEV stack only.
#   Production workloads run on Kubernetes — see infra/k8s/ for manifests.
#   Do NOT use this file for staging or production deployments.
# =============================================================================

version: "3.8"

services:

  # ---------------------------------------------------------------------------
  # fsm-db — PostgreSQL 16 (primary relational datastore)
  # ---------------------------------------------------------------------------
  fsm-db:
    image: postgres:16-alpine
    env_file: .env
    environment:
      POSTGRES_DB: ${POSTGRES_DB:-<project-name>_dev}
      POSTGRES_USER: ${POSTGRES_USER:-<project-name>_user}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
    ports:
      - "${FSM_DB_PORT:-5432}:5432"
    volumes:
      - fsm-db-data:/var/lib/postgresql/data
    networks:
      - fsm-dev
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-<project-name>_user} -d ${POSTGRES_DB:-<project-name>_dev}"]
      interval: 5s
      timeout: 5s
      retries: 10
      start_period: 10s

  # ---------------------------------------------------------------------------
  # fsm-backend — Application backend
  # TODO(<project-name>): set build: context and image: tag once Dockerfile is ready
  # Replace the image below with the project image once built.
  # Reference Dockerfile: infra/docker/Dockerfile.backend.example
  # ---------------------------------------------------------------------------
  fsm-backend:
    # replace with project image once built (e.g. image: ghcr.io/org/<project-name>-backend:dev)
    image: scratch
    env_file: .env
    environment:
      DATABASE_URL: ${DATABASE_URL}
      LOG_LEVEL: ${LOG_LEVEL:-info}
    ports:
      - "${FSM_BACKEND_PORT:-8080}:8080"
    networks:
      - fsm-dev
    depends_on:
      fsm-db:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS http://localhost:8080/health || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 15s

  # ---------------------------------------------------------------------------
  # fsm-kong — API gateway (Kong 3.6, REST↔gRPC transcoding — Article VIII.1)
  # ---------------------------------------------------------------------------
  fsm-kong:
    image: kong:3.6-alpine
    env_file: .env
    environment:
      KONG_DATABASE: "off"
      KONG_DECLARATIVE_CONFIG: /kong/kong.yml
    ports:
      - "8000:8000"
      - "${FSM_KONG_ADMIN_PORT:-8001}:8001"
    volumes:
      - ./infra/kong/kong.yml.example:/kong/kong.yml:ro
    networks:
      - fsm-dev
    depends_on:
      fsm-backend:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS http://localhost:8001/status || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 20s

# =============================================================================
# Networks — single named network; default bridge is FORBIDDEN per standard
# =============================================================================
networks:
  fsm-dev:
    driver: bridge
    name: fsm-dev

# =============================================================================
# Volumes — named volume for PostgreSQL data persistence
# =============================================================================
volumes:
  fsm-db-data:
