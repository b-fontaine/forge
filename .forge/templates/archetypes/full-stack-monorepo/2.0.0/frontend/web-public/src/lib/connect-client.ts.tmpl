// Audit: B.8.9 (b8-9-qwik-web-public, FR-B89-020/021/022/023/024/025)
// Standard: .forge/standards/web-frontend.yaml
//
// Connect-ES v2 browser client wiring (verify-then-pin LIVE 2026-06-03,
// evidence.md P-20). For a BROWSER/Qwik client the transport is
// createConnectTransport from @connectrpc/connect-web (NOT connect-node); the
// client factory is createClient from @connectrpc/connect. Both runtime pins are
// owned by transport.yaml v1.3.0 (^2.0.0; single source of truth) and declared
// in package.json. NO zod import (validation deferred per ADR-B89-003).
//
// The GreeterService descriptor is buf-generated by the es plugin
// (buf.build/bufbuild/es:v2.2.0, target=ts) into ./generated/connect/ — the
// ADR-B89-004 re-pointed buf.gen output path. Connect v2 retired the separate
// *_connect file: the single protobuf-es *_pb file carries the service descriptor.
// Run `task proto` (or `cd shared/protos && buf generate`) to materialise it.
//
// NEVER PUT SECRETS HERE — the backend URL is injected via env, not committed.

import { createClient } from "@connectrpc/connect";
import { createConnectTransport } from "@connectrpc/connect-web";
// Generated by buf (es:v2.2.0, target=ts). Adjust the file name to match your
// proto package once `buf generate` has run against shared/protos/.
import { GreeterService } from "./generated/connect/greeter_pb";

// Backend Connect/HTTP base URL. Resolved from the Vite env at build/runtime;
// `<api-url>` is the scaffold default the adopter overrides per environment.
// In production the request flows Qwik → Envoy Gateway (B.8.4) → Rust backend
// (AT C4: Rel(qwik, envoy)).
const baseUrl: string =
  import.meta.env.PUBLIC_API_URL ?? "<api-url>";

const transport = createConnectTransport({ baseUrl });

/** Connect client for the demo Greeter service (one unary example). */
export const greeterClient = createClient(GreeterService, transport);

/**
 * Demonstrates a single unary Connect call (Greeter.SayHello).
 * Replace with your own service methods once the proto contract is generated.
 */
export async function sayHello(name: string): Promise<string> {
  const res = await greeterClient.sayHello({ name });
  return res.message;
}
