# <!-- Audit: B.1.2 (part of b1-scaffolder, .env.example template) -->
# This file is VERSIONED. Copy it to .env and fill in real values.
# NEVER commit real secrets. .env itself is gitignored.

# ── Database (fsm-db) ──
POSTGRES_DB=<project-name>_dev
POSTGRES_USER=<project-name>_user
POSTGRES_PASSWORD=changeme_local_only
DATABASE_URL=postgres://<project-name>_user:changeme_local_only@fsm-db:5432/<project-name>_dev
FSM_DB_PORT=5432

# ── Backend (fsm-backend) ──
LOG_LEVEL=debug
FSM_BACKEND_PORT=8080
RUST_BACKTRACE=1

# ── OIDC (if the archetype adds auth) ──
# Uncomment and fill in when OIDC provider is configured.
# OIDC_ISSUER=https://auth.example.com
# OIDC_CLIENT_ID=your-client-id-here
# OIDC_REDIRECT_URI=com.example.<project-name>:/oauth2redirect

# ── Observability (Sentry / OTel — optional) ──
# SENTRY_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=
