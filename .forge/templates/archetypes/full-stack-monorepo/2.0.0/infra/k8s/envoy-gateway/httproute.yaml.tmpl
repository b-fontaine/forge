# <!-- Audit: B.8.4 (b8-4-envoy-gateway, FR-B84-012, FR-B84-040) -->
# HTTPRoute → <project-name>-backend. Additive-first (ADR-B84-004): routes to
# the SAME fsm-backend Service the Kong example targets (infra/kong/
# kong.yml.example.tmpl, http port 8080 per the 1.0.0 service.yaml.tmpl),
# enabling canary-by-route migration (plan §4.1). Connect/gRPC-Web
# pass-through — NO gateway-side REST↔gRPC transcoding (ADR-B84-006; that
# ownership belongs to B.8.6). Standard: .forge/standards/gateway.yaml.
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: <project-name>-backend-route
  labels:
    app.kubernetes.io/name: <project-name>
    app.kubernetes.io/component: api-gateway
    app.kubernetes.io/part-of: <project-name>
spec:
  parentRefs:
    - name: <project-name>-gateway          # → the Gateway (gateway.yaml)
  hostnames:
    - <project-name>.example.invalid        # templated; mirrors 1.0.0 ingress host placeholder
  rules:
    - matches:
        - path:
            type: PathPrefix
            value: /
      backendRefs:
        - name: <project-name>-backend       # SAME fsm-backend Service Kong targets (ADR-B84-004)
          port: 8080                          # http port per 1.0.0 service.yaml.tmpl
