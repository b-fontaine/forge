# <!-- Audit: B.8.4 (b8-4-envoy-gateway, FR-B84-021) -->
# Kustomization for the Envoy Gateway DATA-PLANE intent (GatewayClass /
# Gateway / HTTPRoute / BackendTLSPolicy). The CONTROL-PLANE (Envoy Gateway
# controller + Gateway API CRDs) is installed Atlas-side via the OCI Helm
# chart — see README.md. Mirrors the 1.0.0 infra/k8s/base/kustomization shape.
# Standard: .forge/standards/gateway.yaml + infra/k8s-overlays.md.
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

resources:
  - gatewayclass.yaml
  - gateway.yaml
  - httproute.yaml
  - backendtlspolicy.yaml
  # B.8.12 (b8-12-e2e-migration): Envoy-OIDC JWT validation at the gateway edge.
  # SecurityPolicy folds the JWT provider config in v1.8 (no separate JWTAuthn
  # resource) + a Backend for the Zitadel jwks upstream. ADR-B812-002.
  - security-policy.yaml

commonLabels:
  app.kubernetes.io/name: <project-name>
  app.kubernetes.io/component: api-gateway
  app.kubernetes.io/part-of: <project-name>
