# <!-- Audit: B.7.2 (b7-2-scaffolder, Phase 1) — ai-native-rag/1.0.0 .env.example -->
#
# Copy to .env and fill in local values:  cp .env.example .env
# .env is gitignored and MUST NEVER be committed.

# ── Postgres / pgvector ──
POSTGRES_DB=<project-name>_dev
POSTGRES_USER=<project-name>_user
POSTGRES_PASSWORD=changeme
ARG_DB_PORT=5432
DATABASE_URL=postgres://<project-name>_user:changeme@localhost:5432/<project-name>_dev

# ── Backend ──
ARG_BACKEND_PORT=8080
LOG_LEVEL=info

# ── LLM gateway (in-repo axum proxy → Mistral-EU / vLLM, OpenAI-compatible) ──
# Upstream base URL of the OpenAI-compatible inference endpoint.
LLM_GATEWAY_UPSTREAM_BASE_URL=https://api.mistral.ai/v1
# API key for the upstream provider (leave empty for a local vLLM with no auth).
LLM_GATEWAY_API_KEY=
# Per-request token budget; the gateway refuses + falls back when exceeded (XI.5).
LLM_GATEWAY_TOKEN_BUDGET=8192
# Global kill switch — set to true to force the non-AI fallback path (XI.5).
LLM_GATEWAY_KILL_SWITCH=false

# ── Compliance tier (drives provider selection; T3 forces zero-egress local) ──
# One of: T1 | T2 | T3
FORGE_EU_TIER=T1

# ── Embeddings ──
# Provider for the RAG embeddings pipeline: mistral | local
# T1/T2 default to mistral (with local as the XI.5 fallback); T3 forces local.
EMBEDDINGS_PROVIDER=mistral
# Local embedding model id for fastembed (LocalEmbedder, in-process ONNX).
LOCAL_EMBEDDING_MODEL=AllMiniLML6V2

# ── Identity (Zitadel OIDC — reused B.8.7 substrate) ──
ZITADEL_ISSUER=http://localhost:8081
ZITADEL_CLIENT_ID=

# ── Observability (SigNoz OTLP — reused B.8.8 substrate) ──
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
SIGNOZ_UI_PORT=3301
