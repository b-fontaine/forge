# <!-- Audit: B.1.14 (b1-delivery, FR-IN-009) -->
# Backend dev environment — committed to repo. NEVER put secrets here.
# Secrets go in .env.local (gitignored by the scaffolder's
# .gitignore template).
#
# Provides OTLP/gRPC defaults pointing at the local fsm-otel-collector
# service inside the docker-compose dev network.

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_SERVICE_NAME=forge-fsm-example-backend
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_RESOURCE_ATTRIBUTES=service.namespace=forge-fsm-example,deployment.environment=dev
