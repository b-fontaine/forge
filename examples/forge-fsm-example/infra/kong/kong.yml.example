# <!-- Audit: B.1.2 (part of b1-scaffolder, Kong declarative example) -->
# <!-- This is an EXAMPLE. Copy to infra/kong/kong.yml and edit for your project. -->
#
# Minimal Kong declarative configuration for local dev.
# Uses DB-less mode (KONG_DATABASE=off + KONG_DECLARATIVE_CONFIG=/kong/kong.yml).
#
# Constitutional reference: Article VIII.1 (API gateway via Kong, declarative only).
# Standard: infra/kong — no admin API mutations; all changes go through this file.

_format_version: "3.0"
_transform: true

services:
  - name: forge-fsm-example-backend
    url: http://fsm-backend:8080
    protocol: http
    retries: 3
    connect_timeout: 5000
    read_timeout: 10000
    write_timeout: 10000
    routes:
      - name: forge-fsm-example-api-route
        paths:
          - /api
        strip_path: true
        preserve_host: false
        protocols:
          - http
          - https

  # ── demo-003-rate-limit (added 2026-04-30) ────────────────────
  # Greeter gRPC service with per-route rate-limiting. Demonstrates
  # the multi-layer demo from c1-reference-project. The `policy:
  # local` flag means counters are per Kong node ; horizontal
  # scale requires switching to `cluster` and provisioning a
  # counter backend (documented as a follow-up).
  - name: greeter
    url: grpc://fsm-backend:9090
    protocol: grpc
    routes:
      - name: greeter-v1-route
        paths:
          - /greeting.v1.GreeterService
        protocols:
          - grpc
          - grpcs
        plugins:
          - name: rate-limiting
            config:
              minute: 10
              policy: local
              fault_tolerant: true

# ── W3C trace context preservation (T.5 Phase C, t5-otel-traceparent-e2e) ──
#
# This gateway MUST forward incoming `traceparent` and `tracestate`
# headers verbatim to the upstream service. Kong's default behaviour
# (no `request_transformer` plugin asks to remove them) preserves
# them. DO NOT add a `request_transformer.remove.headers` entry
# stripping these headers.
#
# Why : the example flagship ships an OTel SDK on both layers
# (Rust backend via `tracing-opentelemetry` + Flutter frontend via
# `TracingInterceptor`). A connected trace tree across the gateway
# hop requires `traceparent` to survive the proxy verbatim. See
# `.forge/changes/t5-otel-traceparent-e2e/specs.md` FR-T5-TPE-020..025.
#
# Forward-pointer : the Envoy migration (`b8-envoy-migration`,
# provisional name per `docs/ARCHITECTURE-TARGET.md` ADR-001) will
# ship the same contract with Envoy's `tracing` config block. Until
# then, Kong is the gateway in play.

# Plugins — example: rate limiting applied globally.
# Uncomment and tune for your project.
#
# plugins:
#   - name: rate-limiting
#     config:
#       minute: 60
#       policy: local
#   - name: cors
#     config:
#       origins:
#         - "http://localhost:*"
#       methods:
#         - GET
#         - POST
#         - PUT
#         - PATCH
#         - DELETE
#         - OPTIONS
#       credentials: true
