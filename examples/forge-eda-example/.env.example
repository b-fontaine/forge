# forge-eda-example — local dev environment. Copy to .env and fill in.
# .env is gitignored and MUST NEVER be committed.

# ── Postgres event store ──
POSTGRES_DB=forge-eda-example_dev
POSTGRES_USER=forge-eda-example_user
POSTGRES_PASSWORD=change-me-locally
DATABASE_URL=postgres://forge-eda-example_user:change-me-locally@localhost:5432/forge-eda-example_dev
ARG_DB_PORT=5432

# ── NATS JetStream ──
NATS_URL=nats://localhost:4222
ARG_NATS_PORT=4222

# ── Temporal (optional local-dev overlay; see infra/temporal/) ──
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=forge-eda-example-sagas

# ── Backend ──
ARG_BACKEND_PORT=8080
LOG_LEVEL=info
